# Copie este arquivo para .env e preencha com os valores do seu ambiente.
# Nao versione o arquivo .env real.

# Servidor
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# Banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=preencha_a_senha_do_banco
DB_DATABASE=plano_geral

# TypeORM
# Em producao, prefira false e use migrations.
TYPEORM_SYNCHRONIZE=true
TYPEORM_LOGGING=false

# Autenticacao JWT
# Gere com: openssl rand -base64 64
JWT_SECRET=preencha_com_uma_chave_segura
JWT_EXPIRES_IN=8h
